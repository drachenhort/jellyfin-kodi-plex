<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">500</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>0</posy>
      <width>1920</width>
      <height>1080</height>
      <texture>background.png</texture>
    </control>

    <control type="label">
      <posx>80</posx>
      <posy>40</posy>
      <width>800</width>
      <height>50</height>
      <font>font13</font>
      <label>Search for movies, shows, artists...</label>
    </control>

    <!-- No <label> here (unlike most edit controls) - Kodi draws an edit
         control's label as a static caption to the left of the typed text
         within the same widget, which visually collided with anything
         actually typed into this fairly narrow field. The equivalent hint
         text now lives in its own label at the bottom of the window
         instead (503 below the results grid). texturenofocus/texturefocus
         reuse the same button textures used elsewhere in this skin so the
         field reads as a distinct entry box (with a visible edge) even
         before it's focused, rather than relying on Kodi's undefined
         default edit-control rendering. -->
    <control type="edit" id="500">
      <posx>80</posx>
      <posy>110</posy>
      <width>1200</width>
      <height>50</height>
      <font>font16</font>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onright>501</onright>
      <ondown>502</ondown>
    </control>
    <control type="button" id="501">
      <posx>1300</posx>
      <posy>110</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>Search</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onleft>500</onleft>
      <onright>504</onright>
      <ondown>502</ondown>
    </control>
    <!-- Explicit escape hatch back to Home - Back/Escape alone can get
         eaten by Kodi's on-screen keyboard closing itself (the edit
         control above) instead of reaching the window, which reads as
         "Back doesn't work" here even though it does everywhere else. -->
    <control type="button" id="504">
      <posx>1520</posx>
      <posy>110</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>Home</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onleft>501</onleft>
      <ondown>502</ondown>
    </control>

    <control type="label" id="503">
      <posx>80</posx>
      <posy>180</posy>
      <width>1200</width>
      <height>30</height>
      <font>font13</font>
      <label></label>
    </control>

    <control type="panel" id="502">
      <posx>80</posx>
      <posy>230</posy>
      <width>1760</width>
      <height>800</height>
      <itemgap>20</itemgap>
      <onup>500</onup>
      <itemlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
      </itemlayout>
      <focusedlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <texture border="10">focus-highlight.png</texture>
        </control>
        <control type="image">
          <posx>3</posx>
          <posy>3</posy>
          <width>214</width>
          <height>324</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="label">
          <posy>300</posy>
          <width>220</width>
          <height>30</height>
          <font>font12</font>
          <label>$INFO[ListItem.Label]</label>
        </control>
        <control type="image">
          <posx>92</posx>
          <posy>0</posy>
          <width>36</width>
          <height>22</height>
          <texture>focus-arrow.png</texture>
        </control>
      </focusedlayout>
    </control>
  </controls>
</window>
