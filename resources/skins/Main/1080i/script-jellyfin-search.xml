            </control>
            <control type="image">
              <posx>3</posx>
              <posy>157</posy>
              <width>127</width>
              <height>40</height>
              <texture>focus-turquoise.png</texture>
            </control>
            <control type="label">
              <posx>9</posx>
              <posy>163</posy>
              <width>115</width>
              <height>28</height>
              <font>font12</font>
              <label>$INFO[ListItem.Label]</label>
            </control>
          </focusedlayout>
        </control>
      </control>
    </control>
  </controls>
</window>
