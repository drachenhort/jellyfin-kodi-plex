              <texture>focus-arrow.png</texture>
            </control>
            <control type="image">
              <posx>3</posx>
              <posy>157</posy>
              <width>127</width>
              <height>40</height>
              <texture>focus-turquoise.png</texture>
            </control>
            <control type="label">
              <posx>9</posx>
              <posy>163</posy>
              <width>115</width>
              <height>28</height>
              <font>font12</font>
              <label>$INFO[ListItem.Label]</label>
            </control>
          </focusedlayout>
        </control>
      </control>

      <control type="group">
        <width>1760</width>
        <height>240</height>
        <visible>Integer.IsGreater(Container(510).NumItems,0)</visible>
        <control type="label">
          <posx>0</posx>
          <posy>0</posy>
          <width>1760</width>
          <height>30</height>
          <font>font16</font>
          <label>Music</label>
        </control>
        <control type="list" id="510">
          <posx>0</posx>
          <posy>40</posy>
          <width>1760</width>
          <height>200</height>
          <orientation>horizontal</orientation>
          <itemgap>15</itemgap>
          <onup>509</onup>
