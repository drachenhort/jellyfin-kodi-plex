<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">500</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>0</posy>
      <width>1920</width>
      <height>1080</height>
      <texture>background.png</texture>
    </control>

    <control type="label">
      <posx>80</posx>
      <posy>40</posy>
      <width>800</width>
      <height>50</height>
      <font>font13</font>
      <label>Search for movies, shows, artists...</label>
    </control>

    <!-- No <label> here (unlike most edit controls) - Kodi draws an edit
         control's label as a static caption to the left of the typed text
         within the same widget, which visually collided with anything
         actually typed into this fairly narrow field. The equivalent hint
         text now lives in its own label at the bottom of the window
         instead (503 below the results grid). texturenofocus/texturefocus
         reuse the same button textures used elsewhere in this skin so the
         field reads as a distinct entry box (with a visible edge) even
         before it's focused, rather than relying on Kodi's undefined
         default edit-control rendering. -->
    <control type="edit" id="500">
      <posx>80</posx>
      <posy>110</posy>
      <width>1200</width>
      <height>50</height>
      <font>font16</font>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onright>501</onright>
      <ondown>505</ondown>
    </control>
    <control type="button" id="501">
      <posx>1300</posx>
      <posy>110</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>Search</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onleft>500</onleft>
      <onright>504</onright>
      <ondown>505</ondown>
    </control>
    <!-- Explicit escape hatch back to Home - Back/Escape alone can get
         eaten by Kodi's on-screen keyboard closing itself (the edit
         control above) instead of reaching the window, which reads as
         "Back doesn't work" here even though it does everywhere else. -->
    <control type="button" id="504">
      <posx>1520</posx>
      <posy>110</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>Home</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onleft>501</onleft>
      <ondown>505</ondown>
    </control>

    <!-- Category filter toggles - each click narrows/widens the next
         search's server-side IncludeItemTypes rather than just hiding
         results client-side (see SearchWindow._toggle_filter()). Label text
         ("[x] Movies") carries the checked state since this skin has no
         radiobutton on/off textures of its own to reuse. -->
    <control type="button" id="505">
      <posx>80</posx>
      <posy>180</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>[x] Movies</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onup>500</onup>
      <onright>506</onright>
      <ondown>508</ondown>
    </control>
    <control type="button" id="506">
      <posx>300</posx>
      <posy>180</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>[x] TV Shows</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onup>500</onup>
      <onleft>505</onleft>
      <onright>507</onright>
      <ondown>508</ondown>
    </control>
    <control type="button" id="507">
      <posx>520</posx>
      <posy>180</posy>
      <width>200</width>
      <height>50</height>
      <font>font16</font>
      <label>[x] Music</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onup>500</onup>
      <onleft>506</onleft>
      <ondown>508</ondown>
    </control>

    <control type="label" id="503">
      <posx>80</posx>
      <posy>240</posy>
      <width>1200</width>
      <height>30</height>
      <font>font13</font>
      <label></label>
    </control>

    <!-- Results grouped one row per category (Movies/TV Shows/Music) rather
         than one flat mixed grid - a broad term returning results across
         every category used to read as an undifferentiated wall of posters
         with no way to tell what's what at a glance. Each row is its own
         horizontal list (SearchWindow._search() sorts items into the
         matching one by type) and collapses via NumItems when that
         category came back empty, same pattern as the Home screen's hub
         rows. -->
    <control type="grouplist" id="511">
      <posx>80</posx>
      <posy>290</posy>
      <width>1760</width>
      <height>740</height>
      <orientation>vertical</orientation>
      <itemgap>15</itemgap>
      <scrolltime tween="sine" easing="out">200</scrolltime>
      <onup>505</onup>

      <control type="group">
        <width>1760</width>
        <height>240</height>
        <visible>Integer.IsGreater(Container(508).NumItems,0)</visible>
        <control type="label">
          <posx>0</posx>
          <posy>0</posy>
          <width>1760</width>
          <height>30</height>
          <font>font16</font>
          <label>Movies</label>
        </control>
        <control type="list" id="508">
          <posx>0</posx>
          <posy>40</posy>
          <width>1760</width>
          <height>200</height>
          <orientation>horizontal</orientation>
          <itemgap>15</itemgap>
          <onup>505</onup>
          <ondown>509</ondown>
          <itemlayout width="133" height="200">
            <control type="image">
              <width>133</width>
              <height>200</height>
              <aspectratio>scale</aspectratio>
              <texture>$INFO[ListItem.Art(thumb)]</texture>
            </control>
            <control type="image">
              <posy>160</posy>
              <width>133</width>
              <height>40</height>
              <texture>gradient-overlay.png</texture>
            </control>
            <control type="label">
              <posx>6</posx>
              <posy>166</posy>
              <width>121</width>
              <height>28</height>
              <font>font12</font>
              <label>$INFO[ListItem.Label]</label>
            </control>
          </itemlayout>
          <focusedlayout width="133" height="200">
            <control type="image">
              <width>133</width>
              <height>200</height>
              <texture border="10">focus-highlight.png</texture>
            </control>
            <control type="image">
              <posx>3</posx>
              <posy>3</posy>
              <width>127</width>
              <height>194</height>
              <aspectratio>scale</aspectratio>
              <texture>$INFO[ListItem.Art(thumb)]</texture>
            </control>
            <control type="image">
              <posx>55</posx>
              <posy>0</posy>
              <width>36</width>
              <height>22</height>
              <texture>focus-arrow.png</texture>
            </control>
            <control type="image">
              <posx>3</posx>
              <posy>157</posy>
              <width>127</width>
              <height>40</height>
              <texture>focus-turquoise.png</texture>
            </control>
            <control type="label">
              <posx>9</posx>
              <posy>163</posy>
              <width>115</width>
              <height>28</height>
              <font>font12</font>
              <label>$INFO[ListItem.Label]</label>
            </control>
          </focusedlayout>
        </control>
      </control>

      <control type="group">
        <width>1760</width>
        <height>240</height>
        <visible>Integer.IsGreater(Container(509).NumItems,0)</visible>
        <control type="label">
          <posx>0</posx>
          <posy>0</posy>
          <width>1760</width>
          <height>30</height>
          <font>font16</font>
          <label>TV Shows</label>
        </control>
        <control type="list" id="509">
          <posx>0</posx>
          <posy>40</posy>
          <width>1760</width>
          <height>200</height>
          <orientation>horizontal</orientation>
          <itemgap>15</itemgap>
          <onup>508</onup>
          <ondown>510</ondown>
          <itemlayout width="133" height="200">
