<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">300</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>0</posy>
      <width>1920</width>
      <height>1080</height>
      <texture>background.png</texture>
    </control>

    <control type="label">
      <posx>160</posx>
      <posy>120</posy>
      <width>800</width>
      <height>60</height>
      <font>font32</font>
      <label>Servers</label>
    </control>

    <control type="list" id="300">
      <posx>160</posx>
      <posy>220</posy>
      <width>1200</width>
      <height>600</height>
      <itemgap>4</itemgap>
      <onright>301</onright>
      <onleft>300</onleft>
      <onup>300</onup>
      <ondown>300</ondown>
      <itemlayout width="1200" height="50">
        <control type="label">
          <posx>10</posx>
          <width>1180</width>
          <height>50</height>
          <font>font13</font>
          <label>$INFO[ListItem.Label]</label>
        </control>
      </itemlayout>
      <focusedlayout width="1200" height="50">
        <control type="image">
          <width>1200</width>
          <height>50</height>
          <texture>button-focus.png</texture>
        </control>
        <control type="label">
          <posx>10</posx>
          <width>1180</width>
          <height>50</height>
          <font>font13</font>
          <label>$INFO[ListItem.Label]</label>
        </control>
      </focusedlayout>
    </control>

    <control type="button" id="301">
      <posx>1420</posx>
      <posy>220</posy>
      <width>340</width>
      <height>60</height>
      <font>font13</font>
      <label>Add Server</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onleft>300</onleft>
      <onup>301</onup>
      <ondown>302</ondown>
    </control>
    <control type="button" id="302">
      <posx>1420</posx>
      <posy>300</posy>
      <width>340</width>
      <height>60</height>
      <font>font13</font>
      <label>Remove</label>
      <texturefocus>button-focus.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onleft>300</onleft>
      <onup>301</onup>
      <ondown>302</ondown>
    </control>

    <control type="label" id="303">
      <posx>160</posx>
      <posy>840</posy>
      <width>1200</width>
      <height>60</height>
      <font>font13</font>
      <label></label>
    </control>
  </controls>
</window>
