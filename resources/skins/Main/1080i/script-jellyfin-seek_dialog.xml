<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">100</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>860</posy>
      <width>1920</width>
      <height>220</height>
      <texture>osd-gradient.png</texture>
    </control>

    <control type="label" id="203">
      <posx>60</posx>
      <posy>878</posy>
      <width>1700</width>
      <height>36</height>
      <font>font16</font>
      <label></label>
    </control>

    <control type="progress" id="300">
      <posx>60</posx>
      <posy>935</posy>
      <width>1800</width>
      <height>16</height>
      <info>Player.Progress</info>
      <texturebg border="7">osd-progress-bg.png</texturebg>
      <midtexture border="7">osd-progress-fill.png</midtexture>
    </control>

    <control type="label">
      <posx>60</posx>
      <posy>958</posy>
      <width>200</width>
      <height>30</height>
      <font>font12</font>
      <label>$INFO[Player.Time]</label>
    </control>
    <control type="label">
      <posx>1660</posx>
      <posy>958</posy>
      <width>200</width>
      <height>30</height>
      <font>font12</font>
      <align>right</align>
      <label>-$INFO[Player.TimeRemaining]</label>
    </control>

    <!-- Transport row: rewind / play-or-pause / forward, centered. The
         play/pause button is two controls sharing id=100 (Kodi's standard
         toggle-icon idiom) so lib/windows/seekdialog.py's click handling
         doesn't need to know which state is showing - only one is ever
         visible, gated on the Player.Paused boolean condition. It stays
         accented orange in both states, using a zoom animation rather than
         a texture swap for focus feedback (matching the poster rows
         elsewhere in this addon), since a focus-color swap would clash
         with the always-on accent. -->
    <control type="button" id="101">
      <posx>775</posx>
      <posy>980</posy>
      <width>90</width>
      <height>90</height>
      <label></label>
      <texturenofocus>osd-rewind-nofocus.png</texturenofocus>
      <texturefocus>osd-rewind-focus.png</texturefocus>
      <onleft>101</onleft>
      <onright>100</onright>
    </control>

    <control type="button" id="100">
      <posx>905</posx>
      <posy>970</posy>
      <width>110</width>
      <height>110</height>
      <label></label>
      <texturenofocus>osd-pause.png</texturenofocus>
      <texturefocus>osd-pause.png</texturefocus>
      <visible>!Player.Paused</visible>
      <animation effect="zoom" start="100" end="112" center="auto" time="150" tween="quadratic" easing="out">Focus</animation>
      <animation effect="zoom" start="112" end="100" center="auto" time="150" tween="quadratic" easing="out">UnFocus</animation>
      <onleft>101</onleft>
      <onright>102</onright>
    </control>
    <control type="button" id="100">
      <posx>905</posx>
      <posy>970</posy>
      <width>110</width>
      <height>110</height>
      <label></label>
      <texturenofocus>osd-play.png</texturenofocus>
      <texturefocus>osd-play.png</texturefocus>
      <visible>Player.Paused</visible>
      <animation effect="zoom" start="100" end="112" center="auto" time="150" tween="quadratic" easing="out">Focus</animation>
      <animation effect="zoom" start="112" end="100" center="auto" time="150" tween="quadratic" easing="out">UnFocus</animation>
      <onleft>101</onleft>
      <onright>102</onright>
    </control>

    <control type="button" id="102">
      <posx>1055</posx>
      <posy>980</posy>
      <width>90</width>
      <height>90</height>
      <label></label>
      <texturenofocus>osd-forward-nofocus.png</texturenofocus>
      <texturefocus>osd-forward-focus.png</texturefocus>
      <onleft>100</onleft>
      <onright>105</onright>
    </control>

    <!-- Audio track, subtitles, and close/stop - corner-positioned like
         Plex's OSD buttons rather than inline with the transport controls.
         Audio and subtitles each open a native Kodi selection list of the
         available languages/tracks (subtitles include an "Off" option) -
         see lib/windows/seekdialog.py's _choose_audio()/_choose_subtitle(). -->
    <control type="button" id="105">
      <posx>1640</posx>
      <posy>880</posy>
      <width>70</width>
      <height>70</height>
      <label></label>
      <texturenofocus>osd-audio-nofocus.png</texturenofocus>
      <texturefocus>osd-audio-focus.png</texturefocus>
      <onleft>102</onleft>
      <onright>104</onright>
    </control>
    <control type="button" id="104">
      <posx>1730</posx>
      <posy>880</posy>
      <width>70</width>
      <height>70</height>
      <label></label>
      <texturenofocus>osd-subtitles-nofocus.png</texturenofocus>
      <texturefocus>osd-subtitles-focus.png</texturefocus>
      <onleft>105</onleft>
      <onright>103</onright>
    </control>

    <control type="button" id="103">
      <posx>1820</posx>
      <posy>880</posy>
      <width>70</width>
      <height>70</height>
      <label></label>
      <texturenofocus>osd-close-nofocus.png</texturenofocus>
      <texturefocus>osd-close-focus.png</texturefocus>
      <onleft>104</onleft>
      <onright>103</onright>
    </control>
  </controls>
</window>
