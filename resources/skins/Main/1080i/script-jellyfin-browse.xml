<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">301</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>0</posy>
      <width>1920</width>
      <height>1080</height>
      <texture>background.png</texture>
    </control>

    <control type="label" id="300">
      <posx>80</posx>
      <posy>40</posy>
      <width>1200</width>
      <height>50</height>
      <font>font32</font>
      <label></label>
    </control>

    <!-- Album screens only (BrowseWindow hides these otherwise): play every
         track in listing order, or in a shuffled order. -->
    <control type="button" id="302">
      <posx>1580</posx>
      <posy>45</posy>
      <width>140</width>
      <height>50</height>
      <font>font16</font>
      <label>Play All</label>
      <texturefocus border="10">focus-highlight.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onright>303</onright>
      <onleft>302</onleft>
      <ondown>301</ondown>
      <onup>302</onup>
    </control>
    <control type="button" id="303">
      <posx>1740</posx>
      <posy>45</posy>
      <width>140</width>
      <height>50</height>
      <font>font16</font>
      <label>Shuffle</label>
      <texturefocus border="10">focus-highlight.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onright>303</onright>
      <onleft>302</onleft>
      <ondown>301</ondown>
      <onup>303</onup>
    </control>

    <control type="panel" id="301">
      <posx>80</posx>
      <posy>130</posy>
      <width>1760</width>
      <height>660</height>
      <onup>302</onup>
      <itemgap>20</itemgap>
      <itemlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="image">
          <posy>274</posy>
          <width>220</width>
          <height>56</height>
          <texture>gradient-overlay.png</texture>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="label">
          <posx>10</posx>
          <posy>278</posy>
          <width>200</width>
          <height>20</height>
          <font>font12</font>
          <label>$INFO[ListItem.Property(ratings_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="image">
          <posx>172</posx>
          <posy>8</posy>
          <width>40</width>
          <height>40</height>
          <texture>watched-badge.png</texture>
          <visible>ListItem.Property(watched)</visible>
        </control>
        <control type="image">
          <posx>8</posx>
          <posy>8</posy>
          <width>64</width>
          <height>40</height>
          <texture>unwatched-badge.png</texture>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
        <control type="label">
          <posx>8</posx>
          <posy>8</posy>
          <width>64</width>
          <height>40</height>
          <font>font12</font>
          <align>center</align>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(unwatched_count)]</label>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
      </itemlayout>
      <focusedlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <texture border="10">focus-highlight.png</texture>
        </control>
        <control type="image">
          <posx>3</posx>
          <posy>3</posy>
          <width>214</width>
          <height>324</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="image">
          <posx>3</posx>
          <posy>274</posy>
          <width>214</width>
          <height>56</height>
          <texture>focus-turquoise.png</texture>
        </control>
        <control type="label">
          <posx>13</posx>
          <posy>278</posy>
          <width>194</width>
          <height>20</height>
          <font>font12</font>
          <label>$INFO[ListItem.Property(ratings_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="label">
          <posy>300</posy>
          <width>220</width>
          <height>30</height>
          <font>font12</font>
          <label>$INFO[ListItem.Label]</label>
        </control>
        <control type="image">
          <posx>92</posx>
          <posy>0</posy>
          <width>36</width>
          <height>22</height>
          <texture>focus-arrow.png</texture>
        </control>
        <control type="image">
          <posx>168</posx>
          <posy>28</posy>
          <width>40</width>
          <height>40</height>
          <texture>watched-badge.png</texture>
          <visible>ListItem.Property(watched)</visible>
        </control>
        <control type="image">
          <posx>8</posx>
          <posy>28</posy>
          <width>64</width>
          <height>40</height>
          <texture>unwatched-badge.png</texture>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
        <control type="label">
          <posx>8</posx>
          <posy>28</posy>
          <width>64</width>
          <height>40</height>
          <font>font12</font>
          <align>center</align>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(unwatched_count)]</label>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
      </focusedlayout>
    </control>

    <!-- A season's episodes get an "ls -l"-style detail list instead of the
         poster grid above - one row per episode (thumb, code, title,
         duration, watched state) is a lot more scannable than a wall of
         near-identical landscape thumbnails. BrowseWindow toggles which of
         301/304 is visible and populated based on parent_item_type. -->
    <control type="list" id="304">
      <posx>80</posx>
      <posy>130</posy>
      <width>1760</width>
      <height>660</height>
      <onup>302</onup>
      <itemgap>6</itemgap>
      <itemlayout width="1760" height="84">
        <control type="image">
          <posy>2</posy>
          <width>150</width>
          <height>80</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="label">
          <posx>165</posx>
          <width>85</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(episode_code)]</label>
        </control>
        <control type="label">
          <posx>260</posx>
          <width>850</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Title]</label>
        </control>
        <control type="label">
          <posx>1120</posx>
          <width>100</width>
          <height>84</height>
          <font>font13</font>
          <align>right</align>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Duration(mins)] min</label>
          <visible>Integer.IsGreater(ListItem.Duration,0)</visible>
        </control>
        <control type="label">
          <posx>1240</posx>
          <width>190</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(ratings_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="label">
          <posx>1440</posx>
          <width>150</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(progress_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(progress_text))</visible>
        </control>
        <control type="image">
          <posx>1610</posx>
          <posy>22</posy>
          <width>40</width>
          <height>40</height>
          <texture>watched-badge.png</texture>
          <visible>ListItem.Property(watched)</visible>
        </control>
      </itemlayout>
      <focusedlayout width="1760" height="84">
        <control type="image">
          <width>1760</width>
          <height>84</height>
          <texture border="6">focus-highlight.png</texture>
        </control>
        <control type="image">
          <posx>4</posx>
          <posy>6</posy>
          <width>150</width>
          <height>80</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="label">
          <posx>169</posx>
          <width>85</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(episode_code)]</label>
        </control>
        <control type="label">
          <posx>264</posx>
          <width>840</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Title]</label>
        </control>
        <control type="label">
          <posx>1120</posx>
          <width>100</width>
          <height>84</height>
          <font>font13</font>
          <align>right</align>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Duration(mins)] min</label>
          <visible>Integer.IsGreater(ListItem.Duration,0)</visible>
        </control>
        <control type="label">
          <posx>1240</posx>
          <width>190</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(ratings_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="label">
          <posx>1440</posx>
          <width>150</width>
          <height>84</height>
          <font>font13</font>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(progress_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(progress_text))</visible>
        </control>
        <control type="image">
          <posx>1610</posx>
          <posy>22</posy>
          <width>40</width>
          <height>40</height>
          <texture>watched-badge.png</texture>
          <visible>ListItem.Property(watched)</visible>
        </control>
      </focusedlayout>
    </control>

    <!-- Synopsis pane for the focused item, whichever of the poster grid
         (301) or episode list (304) is currently active - only one is ever
         populated per screen instance, so concatenating both container refs
         is safe: the inactive one is always empty. No Python wiring needed
         beyond list_item() already calling setPlot(). Collapses to blank
         space rather than being hidden outright when there's no Overview. -->
    <control type="label">
      <posx>80</posx>
      <posy>810</posy>
      <width>1760</width>
      <height>30</height>
      <font>font16</font>
      <label>$INFO[Container(301).ListItem.Label]$INFO[Container(304).ListItem.Label]</label>
      <visible>!String.IsEmpty(Container(301).ListItem.Plot) | !String.IsEmpty(Container(304).ListItem.Plot)</visible>
    </control>
    <control type="textbox">
      <posx>80</posx>
      <posy>845</posy>
      <width>1760</width>
      <height>185</height>
      <font>font13</font>
      <label>$INFO[Container(301).ListItem.Plot]$INFO[Container(304).ListItem.Plot]</label>
      <visible>!String.IsEmpty(Container(301).ListItem.Plot) | !String.IsEmpty(Container(304).ListItem.Plot)</visible>
    </control>

    <!-- Transient loading overlay: shown while _load() is still fetching in
         the background so the screen doesn't read as frozen on a slow/large
         library, hidden once it finishes (lib/windows/browse.py). Placed
         last so it renders on top of everything else, centered on screen
         rather than docked in the header - the backdrop panel's visibility
         tracks the label control (305) directly rather than needing its own
         id/Python wiring. -->
    <control type="image">
      <posx>560</posx>
      <posy>495</posy>
      <width>800</width>
      <height>90</height>
      <texture colordiffuse="D0000000">white.png</texture>
      <visible>Control.IsVisible(305)</visible>
    </control>
    <control type="label" id="305">
      <posx>560</posx>
      <posy>495</posy>
      <width>800</width>
      <height>90</height>
      <font>font16</font>
      <align>center</align>
      <aligny>center</aligny>
      <label>Loading…</label>
    </control>
  </controls>
</window>
