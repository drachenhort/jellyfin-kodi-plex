<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">301</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>0</posy>
      <width>1920</width>
      <height>1080</height>
      <texture>background.png</texture>
    </control>

    <control type="label" id="300">
      <posx>80</posx>
      <posy>40</posy>
      <width>1200</width>
      <height>50</height>
      <font>font32</font>
      <label></label>
    </control>

    <!-- Album screens only (BrowseWindow hides these otherwise): play every
         track in listing order, or in a shuffled order. -->
    <control type="button" id="302">
      <posx>1580</posx>
      <posy>45</posy>
      <width>140</width>
      <height>50</height>
      <font>font16</font>
      <label>Play All</label>
      <texturefocus border="10">focus-highlight.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onright>303</onright>
      <onleft>302</onleft>
      <ondown>301</ondown>
      <onup>302</onup>
    </control>
    <control type="button" id="303">
      <posx>1740</posx>
      <posy>45</posy>
      <width>140</width>
      <height>50</height>
      <font>font16</font>
      <label>Shuffle</label>
      <texturefocus border="10">focus-highlight.png</texturefocus>
      <texturenofocus>button-nofocus.png</texturenofocus>
      <onright>303</onright>
      <onleft>302</onleft>
      <ondown>301</ondown>
      <onup>303</onup>
    </control>

    <control type="panel" id="301">
      <posx>80</posx>
      <posy>130</posy>
      <width>1760</width>
      <height>900</height>
      <onup>302</onup>
      <itemgap>20</itemgap>
      <itemlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="image">
          <posy>274</posy>
          <width>220</width>
          <height>56</height>
          <texture>gradient-overlay.png</texture>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="label">
          <posx>10</posx>
          <posy>278</posy>
          <width>200</width>
          <height>20</height>
          <font>font12</font>
          <label>$INFO[ListItem.Property(ratings_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="image">
          <posx>172</posx>
          <posy>8</posy>
          <width>40</width>
          <height>40</height>
          <texture>watched-badge.png</texture>
          <visible>ListItem.Property(watched)</visible>
        </control>
        <control type="image">
          <posx>8</posx>
          <posy>8</posy>
          <width>64</width>
          <height>40</height>
          <texture>unwatched-badge.png</texture>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
        <control type="label">
          <posx>8</posx>
          <posy>8</posy>
          <width>64</width>
          <height>40</height>
          <font>font12</font>
          <align>center</align>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(unwatched_count)]</label>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
      </itemlayout>
      <focusedlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <texture border="10">focus-highlight.png</texture>
        </control>
        <control type="image">
          <posx>3</posx>
          <posy>3</posy>
          <width>214</width>
          <height>324</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="image">
          <posx>3</posx>
          <posy>274</posy>
          <width>214</width>
          <height>56</height>
          <texture>focus-turquoise.png</texture>
        </control>
        <control type="label">
          <posx>13</posx>
          <posy>278</posy>
          <width>194</width>
          <height>20</height>
          <font>font12</font>
          <label>$INFO[ListItem.Property(ratings_text)]</label>
          <visible>!String.IsEmpty(ListItem.Property(ratings_text))</visible>
        </control>
        <control type="label">
          <posy>300</posy>
          <width>220</width>
          <height>30</height>
          <font>font12</font>
          <label>$INFO[ListItem.Label]</label>
        </control>
        <control type="image">
          <posx>92</posx>
          <posy>0</posy>
          <width>36</width>
          <height>22</height>
          <texture>focus-arrow.png</texture>
        </control>
        <control type="image">
          <posx>168</posx>
          <posy>28</posy>
          <width>40</width>
          <height>40</height>
          <texture>watched-badge.png</texture>
          <visible>ListItem.Property(watched)</visible>
        </control>
        <control type="image">
          <posx>8</posx>
          <posy>28</posy>
          <width>64</width>
          <height>40</height>
          <texture>unwatched-badge.png</texture>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
        <control type="label">
          <posx>8</posx>
          <posy>28</posy>
          <width>64</width>
          <height>40</height>
          <font>font12</font>
          <align>center</align>
          <aligny>center</aligny>
          <label>$INFO[ListItem.Property(unwatched_count)]</label>
          <visible>!String.IsEmpty(ListItem.Property(unwatched_count))</visible>
        </control>
      </focusedlayout>
    </control>
  </controls>
</window>
