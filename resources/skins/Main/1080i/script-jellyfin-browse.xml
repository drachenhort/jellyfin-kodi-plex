<?xml version="1.0" encoding="UTF-8"?>
<window>
  <defaultcontrol always="true">301</defaultcontrol>
  <controls>
    <control type="image">
      <posx>0</posx>
      <posy>0</posy>
      <width>1920</width>
      <height>1080</height>
      <texture>background.png</texture>
    </control>

    <control type="label" id="300">
      <posx>80</posx>
      <posy>40</posy>
      <width>1200</width>
      <height>50</height>
      <font>font32</font>
      <label></label>
    </control>

    <control type="panel" id="301">
      <posx>80</posx>
      <posy>130</posy>
      <width>1760</width>
      <height>900</height>
      <itemgap>20</itemgap>
      <itemlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
      </itemlayout>
      <focusedlayout width="220" height="330">
        <control type="image">
          <width>220</width>
          <height>330</height>
          <texture border="10">focus-highlight.png</texture>
        </control>
        <control type="image">
          <posx>3</posx>
          <posy>3</posy>
          <width>214</width>
          <height>324</height>
          <aspectratio>scale</aspectratio>
          <texture>$INFO[ListItem.Art(thumb)]</texture>
        </control>
        <control type="label">
          <posy>300</posy>
          <width>220</width>
          <height>30</height>
          <font>font12</font>
          <label>$INFO[ListItem.Label]</label>
        </control>
        <control type="image">
          <posx>92</posx>
          <posy>0</posy>
          <width>36</width>
          <height>22</height>
          <texture>focus-arrow.png</texture>
        </control>
      </focusedlayout>
    </control>
  </controls>
</window>
